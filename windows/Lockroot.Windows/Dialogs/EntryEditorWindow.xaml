<Window x:Class="Lockroot.Windows.Dialogs.EntryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lockroot Entry"
        Width="640"
        Height="720"
        MinWidth="560"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8F4"
        Icon="/Assets/lockroot.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#146B4E" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E7F1EB" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE4DE" />
        <SolidColorBrush x:Key="TextBrush" Color="#151D1A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#65716C" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,16,0,7" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MinWidth" Value="106" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MinWidth" Value="106" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Padding="0"
            Background="White"
            BorderBrush="#DCE4DE"
            BorderThickness="1"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="24,22"
                    Background="#FBFCFA"
                    BorderBrush="#E7ECE8"
                    BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="52"
                            Height="52"
                            Background="#EDE5D8"
                            CornerRadius="14">
                        <Image Source="/Assets/lockroot-icon.png"
                               Width="42"
                               Height="42"
                               Stretch="Uniform" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderText"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Store a credential inside your encrypted local vault."
                                   Margin="0,5,0,0"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,4,24,20">
                <StackPanel>
                    <TextBlock Text="Title" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="TitleBox"
                             Style="{StaticResource InputStyle}"
                             ToolTip="Example: GitHub, Gmail, Bank account" />

                    <TextBlock Text="Website" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="WebsiteBox"
                             Style="{StaticResource InputStyle}"
                             ToolTip="Example: https://github.com" />

                    <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="UsernameBox"
                             Style="{StaticResource InputStyle}"
                             ToolTip="Username, email address, or account ID" />

                    <TextBlock Text="Password" Style="{StaticResource FieldLabelStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PasswordBox"
                                 Style="{StaticResource InputStyle}"
                                 MinWidth="240"
                                 ToolTip="Stored encrypted in the vault" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Content="Generate"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="GeneratePasswordClick" />
                    </Grid>

                    <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="NotesBox"
                             MinHeight="100"
                             Padding="13"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="{StaticResource BorderBrushSoft}"
                             Background="White" />

                    <TextBlock Text="Tags" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="TagsBox"
                             Style="{StaticResource InputStyle}"
                             ToolTip="Comma separated tags, for example: work, email" />

                    <CheckBox x:Name="FavoriteBox"
                              Content="Mark as favorite"
                              Margin="0,18,0,0"
                              Foreground="{StaticResource TextBrush}" />

                    <TextBlock x:Name="ErrorText"
                               Margin="0,14,0,0"
                               Foreground="#B42318"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Padding="24,16"
                    Background="#FBFCFA"
                    BorderBrush="#E7ECE8"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16">
                <WrapPanel HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelClick" />
                    <Button Content="Save Entry"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="SaveClick" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
