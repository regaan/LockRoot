<Window x:Class="Lockroot.Windows.Dialogs.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lockroot"
        Width="500"
        MinWidth="440"
        MinHeight="360"
        SizeToContent="Height"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8F4"
        Icon="/Assets/lockroot.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#146B4E" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E7F1EB" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE4DE" />
        <SolidColorBrush x:Key="TextBrush" Color="#151D1A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#65716C" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Background="White"
            BorderBrush="#DCE4DE"
            BorderThickness="1"
            CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="22"
                    Background="#FBFCFA"
                    BorderBrush="#E7ECE8"
                    BorderThickness="0,0,0,1"
                    CornerRadius="16,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="48"
                            Height="48"
                            Background="#EDE5D8"
                            CornerRadius="13">
                        <Image Source="/Assets/lockroot-icon.png"
                               Width="38"
                               Height="38"
                               Stretch="Uniform" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock x:Name="MessageText"
                                   Margin="0,5,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   LineHeight="20" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="22,18,22,12">
                <TextBlock x:Name="PasswordLabel"
                           Text="Export password"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MutedTextBrush}" />
                <PasswordBox x:Name="PasswordBox"
                             MinHeight="42"
                             Margin="0,7,0,12"
                             Padding="13,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="{StaticResource BorderBrushSoft}" />
                <TextBlock x:Name="ConfirmPasswordLabel"
                           Text="Confirm export password"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MutedTextBrush}" />
                <PasswordBox x:Name="ConfirmPasswordBox"
                             MinHeight="42"
                             Margin="0,7,0,0"
                             Padding="13,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="{StaticResource BorderBrushSoft}" />
                <TextBlock x:Name="ErrorText"
                           Margin="0,10,0,0"
                           Foreground="#B42318"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="22,16"
                    Background="#FBFCFA"
                    BorderBrush="#E7ECE8"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,16,16">
                <WrapPanel HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelClick" />
                    <Button Content="Continue"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ContinueClick" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
