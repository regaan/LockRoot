<Window x:Class="Lockroot.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lockroot"
        Width="1240"
        Height="780"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F7F8F4"
        Icon="/Assets/lockroot.ico"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SoftPanelBrush" Color="#F3F7F2" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE4DE" />
        <SolidColorBrush x:Key="TextBrush" Color="#151D1A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#65716C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#146B4E" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E7F1EB" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#33403B" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ActionCardStyle" TargetType="Button">
            <Setter Property="Width" Value="188" />
            <Setter Property="MinHeight" Value="92" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="IconBubbleStyle" TargetType="Border">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="CornerRadius" Value="23" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="PasswordInputStyle" TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <Grid>
        <ScrollViewer x:Name="TermsScreen"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel MaxWidth="720"
                            Margin="28"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Border Width="104"
                            Height="104"
                            HorizontalAlignment="Center"
                            Background="#EDE5D8"
                            BorderBrush="#C9BCA8"
                            BorderThickness="1"
                            CornerRadius="26">
                        <Image Source="/Assets/lockroot-icon.png"
                               Margin="10"
                               Stretch="Uniform" />
                    </Border>

                    <TextBlock Text="Before You Create a Vault"
                               Margin="0,26,0,8"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               TextAlignment="Center" />
                    <TextBlock Text="Lockroot is a zero-recovery local password manager. The master password is your responsibility."
                               FontSize="16"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="24" />

                    <Border Margin="0,28,0,0"
                            Padding="24"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock Text="Terms and Conditions"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       LineHeight="23"
                                       Foreground="{StaticResource MutedTextBrush}">
                                <Run Text="1. Lockroot stores vault data locally and does not provide account recovery." />
                                <LineBreak />
                                <Run Text="2. If you forget your master password, the vault cannot be decrypted by Lockroot, Regaan, Camora Technologies, or anyone else." />
                                <LineBreak />
                                <Run Text="3. Export files are encrypted with the export password you choose. Losing that password means losing that export." />
                                <LineBreak />
                                <Run Text="4. You are responsible for choosing a strong password, keeping backups safe, and protecting your device." />
                                <LineBreak />
                                <Run Text="5. The software is provided as-is. No warranty, no recovery backdoor, no silent cloud rescue." />
                            </TextBlock>

                            <CheckBox x:Name="TermsCheckBox"
                                      Margin="0,20,0,0"
                                      Foreground="{StaticResource TextBrush}">
                                <TextBlock Text="I understand and agree to the Terms and Conditions."
                                           TextWrapping="Wrap" />
                            </CheckBox>

                            <TextBlock x:Name="TermsErrorText"
                                       Margin="0,12,0,0"
                                       Foreground="#B42318"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button Content="Agree and Continue"
                            Margin="0,22,0,0"
                            MinHeight="48"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="AcceptTermsClick" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <ScrollViewer x:Name="SetupScreen"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel MaxWidth="480"
                            Margin="24"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch">
                    <Border Width="116"
                            Height="116"
                            HorizontalAlignment="Center"
                            Background="#EDE5D8"
                            BorderBrush="#C9BCA8"
                            BorderThickness="1"
                            CornerRadius="28">
                        <TextBlock Text="&#xE72E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="48"
                                   Foreground="#171411"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Set up your vault"
                               Margin="0,28,0,8"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               TextAlignment="Center" />
                    <TextBlock Text="Create a master password to encrypt your local Windows vault."
                               FontSize="16"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="24" />

                    <Border Margin="0,30,0,0"
                            Padding="24"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock Text="Master Password"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <PasswordBox x:Name="SetupPasswordBox"
                                         Margin="0,8,0,16"
                                         Style="{StaticResource PasswordInputStyle}" />
                            <TextBlock Text="Confirm Password"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <PasswordBox x:Name="SetupConfirmPasswordBox"
                                         Margin="0,8,0,0"
                                         Style="{StaticResource PasswordInputStyle}" />
                            <TextBlock x:Name="SetupErrorText"
                                       Margin="0,14,0,0"
                                       Foreground="#B42318"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button Content="Create Vault"
                            Margin="0,22,0,0"
                            MinHeight="48"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="CreateVaultClick" />
                    <TextBlock Text="No recovery. If the master password is lost, the vault cannot be decrypted."
                               Margin="0,18,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <ScrollViewer x:Name="UnlockScreen"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel MaxWidth="440"
                            Margin="24"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch">
                    <Border Width="108"
                            Height="108"
                            HorizontalAlignment="Center"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="54">
                        <TextBlock Text="&#xE72E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="48"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Unlock vault"
                               Margin="0,28,0,8"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               TextAlignment="Center" />
                    <TextBlock Text="Enter your master password to continue."
                               FontSize="16"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />

                    <Border Margin="0,30,0,0"
                            Padding="24"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock Text="Master Password"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <PasswordBox x:Name="UnlockPasswordBox"
                                         Margin="0,8,0,0"
                                         Style="{StaticResource PasswordInputStyle}" />
                            <TextBlock x:Name="UnlockErrorText"
                                       Margin="0,14,0,0"
                                       Foreground="#B42318"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button Content="Unlock"
                            Margin="0,22,0,0"
                            MinHeight="48"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="UnlockVaultClick" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="VaultShell" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FDFEFC"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                        <Border Width="42"
                                Height="42"
                                Background="#EDE5D8"
                                CornerRadius="13">
                            <Image Source="/Assets/lockroot-icon.png"
                                   Width="34"
                                   Height="34"
                                   Stretch="Uniform" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Lockroot"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="Password Manager"
                                       Margin="0,5,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Button Style="{StaticResource SidebarButtonStyle}" Click="ShowAllEntriesClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Grid.Column="1" Text="Home" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}" Click="ShowAllEntriesClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Grid.Column="1" Text="All Entries" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}" Click="ShowFavoritesClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Grid.Column="1" Text="Favorites" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>

                            <TextBlock Text="TOOLS"
                                       Margin="0,22,0,8"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <Button Style="{StaticResource SidebarButtonStyle}" Click="OpenGeneratorClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Grid.Column="1" Text="Password Generator" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}" Click="ImportVaultClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Grid.Column="1" Text="Import" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}" Click="ExportVaultClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Grid.Column="1" Text="Export" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>

                            <TextBlock Text="SECURITY"
                                       Margin="0,22,0,8"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <Button Style="{StaticResource SidebarButtonStyle}" Click="LockVaultClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Grid.Column="1" Text="Lock Vault" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="14"
                            Background="#F4F8F5"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock x:Name="VaultPathText"
                                   FontSize="12"
                                   LineHeight="18"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="34,26,30,30">
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox"
                                 MinWidth="220"
                                 MaxWidth="560"
                                 HorizontalAlignment="Stretch"
                                 Margin="0,0,16,0"
                                 Style="{StaticResource InputStyle}"
                                 TextChanged="SearchTextChanged" />
                        <Button Grid.Column="1"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="AddEntryClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+"
                                           Margin="0,-2,8,0"
                                           FontSize="22" />
                                <TextBlock Text="Add Entry" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Padding="28"
                            Background="#EEF6F1"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <DockPanel LastChildFill="True">
                            <Border Width="118"
                                    Height="118"
                                    Margin="0,0,26,0"
                                    Background="#EDE5D8"
                                    BorderBrush="#C9BCA8"
                                    BorderThickness="1"
                                    CornerRadius="28"
                                    DockPanel.Dock="Left">
                                <Image Source="/Assets/lockroot-icon.png"
                                       Margin="10"
                                       Stretch="Uniform" />
                            </Border>
                            <StackPanel MinWidth="260">
                                <TextBlock Text="Welcome back!"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Your encrypted Windows vault is unlocked locally."
                                           Margin="0,7,0,18"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                                <WrapPanel>
                                    <Border Width="168"
                                            MinHeight="62"
                                            Margin="0,0,14,10"
                                            Padding="16,10"
                                            Background="White"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="7">
                                        <StackPanel>
                                            <TextBlock x:Name="EntryCountText"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="Total Entries"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Width="168"
                                            MinHeight="62"
                                            Margin="0,0,14,10"
                                            Padding="16,10"
                                            Background="White"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="7">
                                        <StackPanel>
                                            <TextBlock x:Name="FavoriteCountText"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="Favorites"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <WrapPanel Margin="0,18,0,12">
                        <Button Style="{StaticResource ActionCardStyle}" Click="FocusSearchClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource IconBubbleStyle}">
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Search" FontWeight="Bold" />
                                    <TextBlock Text="Find entries" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ActionCardStyle}" Click="AddEntryClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource IconBubbleStyle}">
                                    <TextBlock Text="+" FontSize="30" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Add Entry" FontWeight="Bold" />
                                    <TextBlock Text="Create new" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ActionCardStyle}" Click="ImportVaultClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource IconBubbleStyle}">
                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Import" FontWeight="Bold" />
                                    <TextBlock Text="Encrypted file" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ActionCardStyle}" Click="ExportVaultClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource IconBubbleStyle}">
                                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Export" FontWeight="Bold" />
                                    <TextBlock Text="Encrypted file" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ActionCardStyle}" Click="OpenGeneratorClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource IconBubbleStyle}">
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Generator" FontWeight="Bold" />
                                    <TextBlock Text="CSPRNG password" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </WrapPanel>

                    <Border MinHeight="260"
                            Padding="22"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <StackPanel x:Name="EmptyState"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="420">
                                <Image Source="/Assets/lockroot-icon.png"
                                       Width="96"
                                       Height="96"
                                       Stretch="Uniform" />
                                <TextBlock Text="No entries yet"
                                           Margin="0,14,0,0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Add your first entry to get started."
                                           Margin="0,8,0,20"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                                <Button Content="Add Entry"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="AddEntryClick" />
                            </StackPanel>

                            <ItemsControl x:Name="EntriesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="16"
                                                Background="#FBFCFA"
                                                BorderBrush="#E1E8E2"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="17"
                                                           FontWeight="Bold"
                                                           Foreground="#151D1A"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Website}"
                                                           Margin="0,4,0,0"
                                                           Foreground="#65716C"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Username}"
                                                           Margin="0,4,0,0"
                                                           Foreground="#65716C"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TagsDisplay}"
                                                           Margin="0,8,0,0"
                                                           Foreground="#146B4E"
                                                           TextWrapping="Wrap" />
                                                <WrapPanel Margin="0,14,0,-8">
                                                    <Button Content="Copy"
                                                            Tag="{Binding Id}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Click="CopyPasswordClick" />
                                                    <Button Content="Edit"
                                                            Tag="{Binding Id}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Click="EditEntryClick" />
                                                    <Button Content="Delete"
                                                            Tag="{Binding Id}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Click="DeleteEntryClick" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
